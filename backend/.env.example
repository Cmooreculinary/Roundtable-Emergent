# SQLite database location
DB_NAME=roundtable_vo
SQLITE_PATH=data/roundtable_vo.sqlite3

# Local file upload storage
UPLOAD_ROOT=data/uploads
APP_NAME=Roundtable_VO

# Render production values should point at the persistent disk:
# SQLITE_PATH=/opt/data/roundtable_vo.sqlite3
# UPLOAD_ROOT=/opt/data/uploads

# JWT signing secret — generate a strong random string
JWT_SECRET=change_me_to_a_long_random_string

# Allowed frontend origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://your-frontend.onrender.com

# Web Push (VAPID) — generate with: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.private_key, v.public_key)"
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=you@example.com

# Twilio SMS (optional — leave blank to disable SMS bridge)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1...

# Anthropic API key (for Smart Suggestions — optional, leave blank to disable)
ANTHROPIC_API_KEY=sk-ant-...
